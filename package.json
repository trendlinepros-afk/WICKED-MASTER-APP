    "axios": "^1.7.9",
    "better-sqlite3": "^12.11.1",
    "chokidar": "^4.0.3",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.3.9",
    "express": "^4.21.2",
    "ffmpeg-static": "^5.2.0",
    "ffprobe-static": "^3.1.0",
    "ignore": "^5.3.2",
    "openai": "^6.42.0",
    "pdf-parse": "^2.4.5",
    "selfsigned": "^5.5.0",
